{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hockey-desktop-host",
  "version": "1.0.0",
  "identifier": "com.hockey.desktophost",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm run build:overlay && npm run dev -- --port 5174 --strictPort",
    "beforeBuildCommand": "npm run build:all"
  },
  "app": {
    "windows": [
      {
        "title": "Hockey Scoreboard",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../obs-overlay/dist/": "obs-overlay-dist/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
