{
  "name": "hockey-scoreboard",
  "private": true,
  "version": "1.0.2",
  "scripts": {
    "dev:obs-overlay": "npm --prefix apps/obs-overlay run dev",
    "dev:desktop": "npm --prefix apps/desktop-host run tauri:dev",
    "build:obs-overlay": "npm --prefix apps/obs-overlay run build",
    "build:desktop": "npm --prefix apps/desktop-host run tauri:build",
    "dev": "npm run dev:desktop",
    "build": "npm run build:obs-overlay && npm --prefix apps/desktop-host run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
